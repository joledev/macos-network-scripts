# Copy to deploy/netbox/.env and fill in. Keep real secrets out of git.
# Generate strong values:
#   DB_PASSWORD / REDIS_PASSWORD : openssl rand -base64 24
#   SECRET_KEY (>=50 chars)      : openssl rand -base64 50
#   SUPERUSER_API_TOKEN (40 hex) : openssl rand -hex 20

DB_PASSWORD=change-me-db
REDIS_PASSWORD=change-me-redis
SECRET_KEY=change-me-to-a-50+-char-random-string-aaaaaaaaaaaaaaaaaaaa

SUPERUSER_NAME=admin
SUPERUSER_EMAIL=admin@example.com
SUPERUSER_PASSWORD=change-me-admin
# This token is created automatically and is what netkit uses to push:
SUPERUSER_API_TOKEN=0123456789abcdef0123456789abcdef01234567
