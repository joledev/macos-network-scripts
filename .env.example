# macos-network-scripts — local configuration
# Copy to .env and adjust. All variables are optional.

# Preferred interface for scans. If unset, the toolkit auto-selects the
# active default-route interface, preferring Ethernet/USB-Ethernet over Wi-Fi.
# Examples: en0 (Wi-Fi), en7 (USB Ethernet), bridge0 (Thunderbolt Bridge)
# NETKIT_INTERFACE=

# Override target subnet for discovery. Default: subnet of the active interface.
# NETKIT_SUBNET=192.168.1.0/24

# Maximum hosts the toolkit may scan without --force. Larger ranges require
# explicit confirmation. Default: 256 (one /24).
NETKIT_MAX_HOSTS=256

# Default ping target for internet quality checks
NETKIT_PING_TARGETS=1.1.1.1,8.8.8.8

# Domain used for DNS lookup timing tests
NETKIT_DNS_DOMAIN=github.com

# Hosts to test SSH connectivity to (comma-separated, host[:port])
# NETKIT_SSH_TARGETS=github.com:22,gitlab.com:22

# Iperf3 server to use, if available locally
# NETKIT_IPERF_SERVER=

# Output directory (default: ./output)
# NETKIT_OUTPUT_DIR=

# Strict mode: refuse to run scans that require sudo or send raw packets.
# Default: 1 (strict on). Set to 0 only on networks you fully own.
NETKIT_STRICT=1

# Dry-run mode: every subcommand prints the probes it WOULD send and exits
# without executing them. Default: 0. Same as passing --dry-run on the CLI.
# NETKIT_DRY_RUN=0

# Redaction salt: stable token-generation salt for `report --redact`. If
# unset, the report's timestamp is used (tokens differ between reports).
# Set this to a stable string per client/customer so `netkit diff` can
# match by token across redacted reports of the same network.
# NETKIT_REDACTION_SALT=stable-salt-for-client-X

# Brand string shown in the HTML report header. Useful when delivering
# reports to a customer.
# NETKIT_REPORT_BRAND=Network Diagnostic Report
