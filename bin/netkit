#!/usr/bin/env bash
# netkit — main CLI for macos-network-scripts.
#
# Subcommands:
#   doctor                Verify environment, tools, and permissions
#   interfaces            List network interfaces with kind, ip, status, speed
#   discover [--active]   Discover LAN hosts (safe, ARP-only by default)
#   topology [--active]   Map local topology; supports --mermaid output
#   quality               Latency / jitter / packet loss / DNS timing
#   diagnose              Dev-workflow connectivity (GitHub, DNS, Docker, VPN)
#   inventory             OS, hardware and installed tools
#   oui fetch [--force]   Refresh IEEE OUI cache (~/.cache/netkit/oui.txt)
#   report [--active]     Generate combined md/json/mermaid report under output/
#   history [--all]       List past reports under output/ (one-line summary each)
#   diff [A] [B]          Diff two reports (default: previous vs latest)
#
# Global flags (forwarded to subcommands when applicable):
#   --interface <iface>   Force a specific interface (e.g. en7)
#   --subnet <cidr>       Force a specific subnet (e.g. 192.168.1.0/24)
#   --json | --md | --text | --mermaid    Output format (default: text)
#   --active              Send light probes (ping sweep) to populate ARP
#   --force               Bypass safety guards (e.g. large subnet)
#   --yes                 Auto-confirm prompts (also: NETKIT_YES=1)
#   --allow-raw           Allow raw-packet operations like arp-scan
#                         (also: NETKIT_ALLOW_RAW=1)
#   --version, -V         Print version and exit
#   --help, -h            Show this help
#
# Examples:
#   netkit doctor
#   netkit interfaces --md
#   netkit discover --active --interface en7
#   netkit quality --count 30 --targets 1.1.1.1,github.com
#   netkit report --active --include-traceroute

set -euo pipefail

NETKIT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export NETKIT_ROOT
# shellcheck source=../scripts/utils/common.sh
source "${NETKIT_ROOT}/scripts/utils/common.sh"

usage() {
  sed -n '2,30p' "$0" | sed 's/^# \{0,1\}//'
}

# Pre-parse global flags that may appear before the subcommand.
# Anything we don't recognize is passed through to the subcommand intact.
PASS=()
while (( $# )); do
  case "$1" in
    --yes) export NETKIT_YES=1; shift ;;
    --allow-raw) export NETKIT_ALLOW_RAW=1; shift ;;
    --version|-V) echo "netkit 0.1.0"; exit 0 ;;
    -h|--help) usage; exit 0 ;;
    *) PASS+=("$1"); shift ;;
  esac
done
set -- "${PASS[@]}"

CMD="${1:-}"
[[ -z "$CMD" ]] && { usage; exit 0; }
shift || true

case "$CMD" in
  doctor)
    "${NETKIT_ROOT}/bin/netkit-doctor" "$@" ;;
  interfaces)
    "${NETKIT_ROOT}/scripts/discovery/interfaces.sh" "$@" ;;
  discover|hosts)
    "${NETKIT_ROOT}/scripts/discovery/hosts.sh" "$@" ;;
  dns)
    "${NETKIT_ROOT}/scripts/discovery/dns.sh" "$@" ;;
  topology|topo|map)
    "${NETKIT_ROOT}/scripts/topology/map.sh" "$@" ;;
  quality|ping)
    "${NETKIT_ROOT}/scripts/quality/ping.sh" "$@" ;;
  diagnose|diag|dev)
    "${NETKIT_ROOT}/scripts/diagnostics/dev.sh" "$@" ;;
  inventory|inv)
    "${NETKIT_ROOT}/scripts/inventory/system.sh" "$@" ;;
  oui)
    sub="${1:-}"; shift || true
    case "$sub" in
      fetch) "${NETKIT_ROOT}/scripts/utils/oui_fetch.sh" "$@" ;;
      *) log_err "Usage: netkit oui fetch [--force]"; exit 2 ;;
    esac
    ;;
  history)
    "${NETKIT_ROOT}/scripts/reports/history.sh" "$@" ;;
  diff)
    "${NETKIT_ROOT}/scripts/reports/diff.sh" "$@" ;;
  report|all)
    "${NETKIT_ROOT}/scripts/reports/generate.sh" "$@" ;;
  *)
    log_err "Unknown subcommand: $CMD"
    usage
    exit 2
    ;;
esac
