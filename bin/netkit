#!/usr/bin/env bash
# netkit — main CLI for macos-network-scripts.
#
# Subcommands:
#   doctor                Verify environment, tools, and permissions
#   interfaces            List network interfaces with kind, ip, status, speed
#   discover [--active]   Discover LAN hosts (safe, ARP-only by default)
#   fingerprint           Deep per-host probe (ports, HTTP/TLS, role) [--aggressive]
#   ssdp                  UPnP / SSDP discovery (TVs, routers, media, repeaters)
#   ubnt-discover         Ubiquiti device discovery (UniFi / airMAX / EdgeMax)
#   netbios               NetBIOS/NBNS names (Windows/NAS hostname + workgroup)
#   wsd                   WS-Discovery (Windows hosts, printers, scanners)
#   ndp                   IPv6 neighbors (hosts ARP/IPv4 cannot see)
#   vendorscan            Vendor probes (TP-Link Kasa/Tapo, MikroTik MNDP)
#   lldp                  LLDP/CDP capture → switch/port/VLAN (needs --allow-raw)
#   dhcp                  DHCP fingerprint (hostname/vendor/opt-55) (--allow-raw)
#   dns                   Show DNS resolvers and per-service config
#   mdns [--duration N]   Browse Bonjour / mDNS services (model from TXT)
#   topology [--active]   Map local topology; supports --mermaid output
#   quality               Latency / jitter / packet loss / DNS timing
#   speedtest             ISP throughput via Ookla / cloudflare-speed-cli
#   throughput            LAN throughput via iperf3 (--server <host>)
#   diagnose              Dev-workflow connectivity (GitHub, DNS, Docker, VPN)
#   wifi                  Wi-Fi RSSI, channel, security + nearby APs scan
#   cameras               IP camera discovery (ONVIF + RTSP + HTTP fingerprint)
#   starlink              Starlink dish status via gRPC API
#   cert-check            TLS audit for arbitrary host:port (chain, versions, HSTS)
#   snmp                  Read-only SNMP audit (system, interfaces, ARP, bridge FDB)
#   unifi                 UniFi Controller inventory (devices, clients, WLANs)
#   inventory             OS, hardware and installed tools
#   oui fetch [--force]   Refresh IEEE OUI cache (~/.cache/netkit/oui.txt)
#   recon [--active]      One-pass discovery + interactive HTML map + mermaid
#   report [--active]     Generate combined md/json/mermaid report under output/
#   history [--all]       List past reports under output/ (one-line summary each)
#   diff [A] [B]          Diff two reports (default: previous vs latest)
#
# Global flags (forwarded to subcommands when applicable):
#   --interface <iface>   Force a specific interface (e.g. en7)
#   --subnet <cidr>       Force a specific subnet (e.g. 192.168.1.0/24)
#   --json | --md | --text | --mermaid    Output format (default: text)
#   --active              Send light probes (ping sweep) to populate ARP
#   --force               Bypass safety guards (e.g. large subnet)
#   --yes                 Auto-confirm prompts (also: NETKIT_YES=1)
#   --allow-raw           Allow raw-packet operations like arp-scan
#                         (also: NETKIT_ALLOW_RAW=1)
#   --dry-run             Print planned probes without executing them
#                         (also: NETKIT_DRY_RUN=1)
#   --version, -V         Print version and exit
#   --help, -h            Show this help
#
# Examples:
#   netkit doctor
#   netkit interfaces --md
#   netkit discover --active --interface en7
#   netkit quality --count 30 --targets 1.1.1.1,github.com
#   netkit report --active --include-traceroute

set -euo pipefail

NETKIT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export NETKIT_ROOT
# shellcheck source=../scripts/utils/common.sh
source "${NETKIT_ROOT}/scripts/utils/common.sh"

usage() {
  sed -n '2,56p' "$0" | sed 's/^# \{0,1\}//'
}

# Pre-parse global flags that may appear BEFORE the subcommand. Stop at
# the first positional so --help / --version after a subcommand reach the
# subcommand itself (e.g. `netkit quality --help` → ping.sh usage, not the
# global usage).
while (( $# )); do
  case "$1" in
    --yes) export NETKIT_YES=1; shift ;;
    --allow-raw) export NETKIT_ALLOW_RAW=1; shift ;;
    --dry-run) export NETKIT_DRY_RUN=1; shift ;;
    --version|-V)
      v="$(cat "${NETKIT_ROOT}/VERSION" 2>/dev/null || echo unknown)"
      echo "netkit ${v}"; exit 0 ;;
    -h|--help) usage; exit 0 ;;
    *) break ;;
  esac
done

CMD="${1:-}"
[[ -z "$CMD" ]] && { usage; exit 0; }
shift || true

case "$CMD" in
  doctor)
    "${NETKIT_ROOT}/bin/netkit-doctor" "$@" ;;
  interfaces)
    "${NETKIT_ROOT}/scripts/discovery/interfaces.sh" "$@" ;;
  discover|hosts)
    "${NETKIT_ROOT}/scripts/discovery/hosts.sh" "$@" ;;
  fingerprint|fp)
    "${NETKIT_ROOT}/scripts/discovery/fingerprint.sh" "$@" ;;
  ssdp|upnp)
    "${NETKIT_ROOT}/scripts/discovery/ssdp.sh" "$@" ;;
  ubnt-discover|ubiquiti|ubntscan)
    "${NETKIT_ROOT}/scripts/discovery/ubnt.sh" "$@" ;;
  netbios|nbns|nbtscan)
    "${NETKIT_ROOT}/scripts/discovery/netbios.sh" "$@" ;;
  wsd|wsdiscovery)
    "${NETKIT_ROOT}/scripts/discovery/wsd.sh" "$@" ;;
  ndp|neighbors)
    "${NETKIT_ROOT}/scripts/discovery/ndp.sh" "$@" ;;
  vendorscan|vendor)
    "${NETKIT_ROOT}/scripts/discovery/vendorscan.sh" "$@" ;;
  lldp|cdp)
    "${NETKIT_ROOT}/scripts/discovery/lldp.sh" "$@" ;;
  dhcp|bootp)
    "${NETKIT_ROOT}/scripts/discovery/dhcp.sh" "$@" ;;
  dns)
    "${NETKIT_ROOT}/scripts/discovery/dns.sh" "$@" ;;
  mdns|bonjour)
    "${NETKIT_ROOT}/scripts/discovery/mdns.sh" "$@" ;;
  topology|topo|map)
    "${NETKIT_ROOT}/scripts/topology/map.sh" "$@" ;;
  quality|ping)
    "${NETKIT_ROOT}/scripts/quality/ping.sh" "$@" ;;
  speedtest|isp)
    "${NETKIT_ROOT}/scripts/quality/speedtest.sh" "$@" ;;
  throughput|iperf)
    "${NETKIT_ROOT}/scripts/quality/throughput.sh" "$@" ;;
  diagnose|diag|dev)
    "${NETKIT_ROOT}/scripts/diagnostics/dev.sh" "$@" ;;
  wifi|wireless)
    "${NETKIT_ROOT}/scripts/diagnostics/wifi.sh" "$@" ;;
  starlink|dishy)
    "${NETKIT_ROOT}/scripts/diagnostics/starlink.sh" "$@" ;;
  cert-check|cert|tls)
    "${NETKIT_ROOT}/scripts/diagnostics/cert_check.sh" "$@" ;;
  snmp)
    "${NETKIT_ROOT}/scripts/diagnostics/snmp.sh" "$@" ;;
  unifi|ubnt)
    "${NETKIT_ROOT}/scripts/diagnostics/unifi.sh" "$@" ;;
  cameras|onvif)
    "${NETKIT_ROOT}/scripts/discovery/cameras.sh" "$@" ;;
  inventory|inv)
    "${NETKIT_ROOT}/scripts/inventory/system.sh" "$@" ;;
  oui)
    sub="${1:-}"; shift || true
    case "$sub" in
      fetch) "${NETKIT_ROOT}/scripts/utils/oui_fetch.sh" "$@" ;;
      *) log_err "Usage: netkit oui fetch [--force]"; exit 2 ;;
    esac
    ;;
  history)
    "${NETKIT_ROOT}/scripts/reports/history.sh" "$@" ;;
  diff)
    "${NETKIT_ROOT}/scripts/reports/diff.sh" "$@" ;;
  recon|discover-all)
    "${NETKIT_ROOT}/scripts/discovery/recon.sh" "$@" ;;
  report|all)
    "${NETKIT_ROOT}/scripts/reports/generate.sh" "$@" ;;
  *)
    log_err "Unknown subcommand: $CMD"
    usage
    exit 2
    ;;
esac
